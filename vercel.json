{
  "version": 2,
  "routes": [
    {
      "src": "/api/extract",
      "dest": "/api/extract.js"
    },
    {
      "src": "/api/analyze",
      "dest": "/api/analyze.js"
    },
    {
      "src": "/api/biomarkers",
      "dest": "/api/biomarkers.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
